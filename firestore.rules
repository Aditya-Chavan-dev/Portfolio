rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is the authorized administrator
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'adityagchavan310@gmail.com';
    }

    // 1. Welcome Screen
    match /adminConfig/welcomeScreen {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Public Content (Skills, Projects, Experience, Certifications)
    match /live/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /projects/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Testimonials
    match /testimonials/{id} {
      allow read: if true;
      
      // Public can create, but status is FORCED to pending
      allow create: if request.resource.data.status == 'pending' &&
                      request.resource.data.keys().hasAll(['name', 'text', 'status']);
                      
      allow update, delete: if isAdmin();
    }

    // 4. Analytics (Public increment)
    match /analytics/{docId} {
      allow read: if true;
      allow update: if true; // support anonymous visits securely
    }

    // Default: Only admin can touch everything else
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
