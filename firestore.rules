rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Allow public reads for the Welcome Screen dialogue
    match /adminConfig/welcomeScreen {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Allow public reads for public content (Skills, Projects, Experience, Certifications)
    match /live/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /projects/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Allow public reads for Approved Testimonials
    match /testimonials/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny for everything else (e.g., adminConfigs, analytics writes below)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // 4. Specifically allow public increment on analytics
    match /analytics/{docId} {
      allow read: if true;
      allow update: if true; // to support increment() updates on visits securely
    }
  }
}
