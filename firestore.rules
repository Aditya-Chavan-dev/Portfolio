rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user has the hidden administrative badge
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // 1. Welcome Screen
    match /adminConfig/welcomeScreen {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Public Content (Skills, Projects, Experience, Certifications)
    match /live/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /projects/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Testimonials
    match /testimonials/{id} {
      allow read: if true;
      
      // Public can create, but status is FORCED to pending
      allow create: if request.resource.data.status == 'pending' &&
                      request.resource.data.keys().hasAll(['name', 'text', 'status']);
                      
      allow update, delete: if isAdmin();
    }

    // 4. Analytics (Surgically restricted public increments)
    match /analytics/{docId} {
      allow read: if true;
      
      // Public UPDATE: Only allow +1 increments on 'visits' or 'adminVisits' fields
      allow update: if 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visits', 'adminVisits']) &&
        (
          (request.resource.data.get('visits', 0) == resource.data.get('visits', 0) + 1) ||
          (request.resource.data.get('adminVisits', 0) == resource.data.get('adminVisits', 0) + 1)
        ) &&
        request.resource.data.get('visits', 0) is int;

      // Only admins can initialize or wipe analytics
      allow create, delete: if isAdmin();
    }

    // 5. Admin OS (Wing 2 Data & Telemetry)
    match /admin_metrics/{document=**} {
      allow read, write: if isAdmin();
    }
    match /admin_sessions/{document=**} {
      allow read, write: if isAdmin();
    }
    match /admin_snapshots/{document=**} {
      allow read, write: if isAdmin();
    }

    // Default: Deny all by default, only allow admin access
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
